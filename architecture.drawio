<mxfile host="app.diagrams.net" modified="2026-03-22" agent="Anatomy of Honesty" version="24.0.0" type="device">
  <diagram name="Game Architecture" id="arch-main">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="960" math="1" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;Multi-Agent Reputation Game Architecture&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Choi, Lee &amp;amp; Lim (2025) · Sobel (2020)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="10" width="550" height="50" as="geometry"/>
        </mxCell>

        <!-- Configuration -->
        <mxCell id="n1" value="&lt;b&gt;Configuration&lt;/b&gt;&lt;br&gt;n agents · risk composition · cost distributions&lt;br&gt;x₂/x₁ ratio · behavioral prior p_b · miscommunication ε" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="335" y="70" width="500" height="70" as="geometry"/>
        </mxCell>

        <!-- Population Generation -->
        <mxCell id="n2" value="&lt;b&gt;Population Generation&lt;/b&gt;&lt;br&gt;c_l, c_d ~ LogNormal(μ, σ) with Gaussian copula correlation&lt;br&gt;α ~ Composition (risk-loving / neutral / averse)&lt;br&gt;β ~ Normal (altruism parameter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="335" y="180" width="500" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- BT Game -->
        <mxCell id="n3" value="&lt;b&gt;BT Environment&lt;/b&gt;&lt;br&gt;&lt;i&gt;Bad-type Truth-telling&lt;/i&gt;&lt;br&gt;Strategic sender = Bad type&lt;br&gt;Behavioral type = truth-teller&lt;br&gt;Equilibrium: tell truth at θ=0&lt;br&gt;(Proposition 1: deceptive truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="130" y="310" width="260" height="110" as="geometry"/>
        </mxCell>

        <!-- GL Game -->
        <mxCell id="n4" value="&lt;b&gt;GL Environment&lt;/b&gt;&lt;br&gt;&lt;i&gt;Good-type Lying&lt;/i&gt;&lt;br&gt;Strategic sender = Good type&lt;br&gt;Behavioral type = always m=1&lt;br&gt;Equilibrium: lie at θ=1&lt;br&gt;(Proposition 2: non-deceptive lie)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="310" width="260" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrows from Population -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n2" target="n4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- BT Belief System -->
        <mxCell id="n5" value="&lt;b&gt;Bayesian Belief Update&lt;/b&gt;&lt;br&gt;λ(m,θ,v) = Pr(τ=G | m,θ)&lt;br&gt;Receiver action: a(m) = E[θ|m]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="130" y="470" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- GL Belief System -->
        <mxCell id="n6" value="&lt;b&gt;Bayesian Belief Update&lt;/b&gt;&lt;br&gt;λ(m,θ,w) = Pr(τ=G | m,θ)&lt;br&gt;Receiver action: a(m) = E[θ|m]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="470" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" source="n3" target="n5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" source="n4" target="n6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- BT Strategy -->
        <mxCell id="n7" value="&lt;b&gt;Strategy (Proposition 3)&lt;/b&gt;&lt;br&gt;v = P(m=1 | θ=0)&lt;br&gt;EU^a = EU − c_l·𝟙{lie} − c_d·D(m,θ)&lt;br&gt;Deviation driven by c_d (deception aversion)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="130" y="590" width="260" height="80" as="geometry"/>
        </mxCell>

        <!-- GL Strategy -->
        <mxCell id="n8" value="&lt;b&gt;Strategy (Proposition 4)&lt;/b&gt;&lt;br&gt;w = P(m=0 | θ=1)&lt;br&gt;EU^a = EU − c_l·𝟙{lie} − c_d·D(m,θ)&lt;br&gt;Deviation driven by c_l (lying aversion)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="590" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" source="n5" target="n7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" source="n6" target="n8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Round Execution -->
        <mxCell id="n9" value="&lt;b&gt;Round Execution (2-Period Game)&lt;/b&gt;&lt;br&gt;Period 1: θ₁ → sender chooses m₁ → [ε message noise] → receiver action a₁&lt;br&gt;Period 2: θ₂ → myopic play → reputation λ determines a₂&lt;br&gt;Payoff: U = −x₁(a₁−target)² − x₂(a₂−target)² − c_l·𝟙{lie} − c_d·D" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="285" y="720" width="600" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n7" target="n9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n8" target="n9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Classification -->
        <mxCell id="n10" value="&lt;b&gt;Behavioral Classification (Figure 5)&lt;/b&gt;&lt;br&gt;Compare observed strategies across BT &amp;amp; GL environments:&lt;br&gt;Equilibrium (BT✓ GL✓) | Lying-averse (BT✓ GL✗) | Deception-averse (BT✗ GL✓) | Inference Error (BT✗ GL✗)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="285" y="840" width="600" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e10" edge="1" source="n9" target="n10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Welfare -->
        <mxCell id="n11" value="&lt;b&gt;Welfare Analysis &amp;amp; Visualization&lt;/b&gt;&lt;br&gt;KPIs · Distribution plots · Strategy histograms · Joint cost scatter · Equilibrium region map" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="335" y="950" width="500" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e11" edge="1" source="n10" target="n11" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Side annotations -->
        <mxCell id="a1" value="&lt;font color=&quot;#999999&quot;&gt;Sobel (2020)&lt;br&gt;Definition 3: Lie ≡ m ≠ θ&lt;br&gt;Definition 4: Deception ≡&lt;br&gt;|λ(m)−λ(mⁿ)| &gt; 0" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="470" width="100" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="a2" value="&lt;font color=&quot;#999999&quot;&gt;Choi et al. (2025)&lt;br&gt;Section 5: Augmented utility&lt;br&gt;EU^a = EU − c_l·𝟙 − c_d·D" style="text;html=1;align=right;verticalAlign=top;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1050" y="590" width="110" height="70" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
